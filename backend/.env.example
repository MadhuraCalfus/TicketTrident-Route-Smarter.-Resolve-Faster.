# Copy this file to .env and fill in your key to run in live mode.
# Without a key, the app automatically falls back to the keyword baseline
# ("mock mode") — the UI and CLI both work fully offline.
ANTHROPIC_API_KEY=

# Model used for live classification. Defaults to Claude Opus 4.8.
# For a live demo, Claude Haiku 4.5 is a good swap: it's dramatically
# cheaper and faster for a simple classification task like this one, at a
# small accuracy cost. That's a real production tradeoff, not a limitation
# of this project — swap it back to Opus any time by changing this line.
# CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-8

# Alternate live provider if you don't have an Anthropic key. Used only when
# ANTHROPIC_API_KEY above is unset. Get a free key at console.groq.com.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Force the keyword baseline even if an API key is present. Useful for
# testing the "AI is unavailable" fallback path deterministically.
# FORCE_MOCK_MODE=true

# Where the SQLite ticket history lives.
# TICKET_DB_PATH=./data/tickets.db
