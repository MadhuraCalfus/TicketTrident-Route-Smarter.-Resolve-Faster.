# Copy this file to .env and fill in your key to run in live mode.
# Without a key, the app automatically falls back to the keyword baseline
# ("mock mode") — the UI and CLI both work fully offline.
ANTHROPIC_API_KEY=


# Additional live providers. Any combination of these plus ANTHROPIC_API_KEY
# above can be set at once: with more than one configured, the "Compare
# against keyword baseline" option in the UI also runs the same ticket
# through every configured provider and shows them side by side.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Force the keyword baseline even if an API key is present. Useful for
# testing the "AI is unavailable" fallback path deterministically.
# FORCE_MOCK_MODE=true

# Where the SQLite ticket history lives.
# TICKET_DB_PATH=./data/tickets.db

# --- Auth ---
# Signs the JWTs issued at login. Change this to a long random string for
# any real deployment — the default is fine for local dev only.
# JWT_SECRET=dev-secret-change-me-in-production

# The single Admin account. There's no admin table (unlike users/team_members,
# which are real per-account DB rows) — just this one login checked directly.
# ADMIN_EMAIL=admin@tickettrident.local
# ADMIN_PASSWORD=admin

# --- Email (team-member account creation + forgot-password links) ---
# Without these, emails are just printed to the server log instead of sent —
# fine for local dev, but a team lead can't actually receive their password
# or a reset link until real SMTP credentials are set.
#
# Gmail: use an "app password" (Google Account -> Security -> 2-Step
# Verification -> App passwords), not your normal login password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=
# FROM_EMAIL=you@gmail.com

# Base URL of the deployed frontend — used to build the link inside
# password-reset emails. Defaults to the local Vite dev server.
# FRONTEND_URL=http://localhost:5173
